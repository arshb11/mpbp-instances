C_Q3_B_2_6_8_.up = 4.6699999999999999;
C_Q3_B_2_6_9_.up = 4.6699999999999999;
C_Q3_B_2_6_10_.up = 4.6699999999999999;
C_Q3_B_3_1_10_.up = 4.6699999999999999;
C_Q3_B_3_2_10_.up = 4.6699999999999999;
C_Q3_B_3_3_10_.up = 4.6699999999999999;
C_Q3_B_3_4_10_.up = 4.6699999999999999;
C_Q3_B_3_5_10_.up = 4.6699999999999999;
FD_D2_9_.lo = 12;
FD_D2_9_.up = 50;
FD_D2_10_.lo = 7;
FD_D2_10_.up = 50;
FD_D3_9_.lo = 7;
FD_D3_9_.up = 50;
FD_D3_10_.lo = 8;
FD_D3_10_.up = 50;

MODEL GAMS_MODEL /all/ ;
option solprint=off;
option limrow=0;
option limcol=0;
option solvelink=5;
SOLVE GAMS_MODEL USING minlp maximizing GAMS_OBJECTIVE;

Scalars MODELSTAT 'model status', SOLVESTAT 'solve status';
MODELSTAT = GAMS_MODEL.modelstat;
SOLVESTAT = GAMS_MODEL.solvestat;

Scalar OBJEST 'best objective', OBJVAL 'objective value';
OBJEST = GAMS_MODEL.objest;
OBJVAL = GAMS_MODEL.objval;

Scalar NUMVAR 'number of variables';
NUMVAR = GAMS_MODEL.numvar

Scalar NUMEQU 'number of equations';
NUMEQU = GAMS_MODEL.numequ

Scalar NUMDVAR 'number of discrete variables';
NUMDVAR = GAMS_MODEL.numdvar

Scalar NUMNZ 'number of nonzeros';
NUMNZ = GAMS_MODEL.numnz

Scalar ETSOLVE 'time to execute solve statement';
ETSOLVE = GAMS_MODEL.etsolve

